{
  "name": "odoo-node",
  "version": "0.1.1",
  "description": "Typed Odoo JSON-RPC client for Node.js",
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\" vitest.config.ts",
    "format:check": "prettier --check \"src/**/*.ts\" vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "odoo",
    "json-rpc",
    "erp",
    "typescript"
  ],
  "license": "MIT",
  "author": "Clemens Helm <clemens@helmcraft.com> (https://heypinchy.com)",
  "funding": "https://github.com/sponsors/clemenshelm",
  "homepage": "https://github.com/heypinchy/odoo-node#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/heypinchy/odoo-node.git"
  },
  "bugs": {
    "url": "https://github.com/heypinchy/odoo-node/issues"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
